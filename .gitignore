# 3D asset pipeline — binaries stay local (regeneratable from Unity + FBX2glTF)
fbx_export/
src/assets/models/**/*.glb
src/assets/models/**/*.fbx

# Per-Sidekick-part headless render output (~171 MB, ~2870 PNGs).
# Regenerated by Unity Synty Character Creator's `Tools → Export Part
# Thumbnails to Drop4` menu. `src/data/partThumbs.ts` requires these
# at bundle time, so a fresh clone needs ONE Unity export pass before
# `npx expo start --web` compiles. Production ship path is hosting
# these on R2 alongside the GLBs.
src/assets/images/parts/

# Local polish loop runtime artifacts
tools/polish-loop.log
.STOP_POLISH
