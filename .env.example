# Copy this file to `.env.local` (gitignored) and fill in real values.
# `.env.local` is read by tools/gen-art.mjs for image generation.

# ── Art generation backend ──
# Options: 'fal' (default, Flux on fal.ai), 'comfyui' (local ComfyUI),
#          'gemini' (Google Nano Banana)
# ART_BACKEND=fal

# ── fal.ai (default backend) ──
# Get a key at fal.ai → Dashboard → API Keys. Pay-as-you-go, no free
# quota but Flux Dev runs ~$0.025/image and Flux Schnell is ~$0.003.
FAL_KEY=

# Optional: pick a specific fal model. Defaults to fal-ai/flux/dev.
# Options:
#   fal-ai/flux/schnell        Cheapest (~$0.003), 4 steps, fastest
#   fal-ai/flux/dev            Default (~$0.025), 28 steps, quality
#   fal-ai/flux-pro/v1.1       Premium (~$0.05)
#   fal-ai/flux-pro/v1.1-ultra Highest quality (~$0.06)
# FAL_MODEL=fal-ai/flux/dev

# ── Gemini Nano Banana (fallback) ──
# Get a key at aistudio.google.com → Get API key. Free tier available,
# resets daily. Pay-as-you-go via Google Cloud billing for unlimited.
GOOGLE_API_KEY=

# ── ComfyUI (local fallback) ──
# Requires ComfyUI running locally with --listen flag. Free, no API.
# COMFY_URL=http://127.0.0.1:8188
# COMFY_CHECKPOINT=sd_xl_base_1.0.safetensors
