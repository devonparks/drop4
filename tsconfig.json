{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@amg/character-runtime": ["../amg-engine/packages/character-runtime/src/index"],
      "@amg/character-runtime/*": ["../amg-engine/packages/character-runtime/src/*"],
      "@amg/character-creator": ["../amg-engine/packages/character-creator/src/index"],
      "@amg/character-creator/*": ["../amg-engine/packages/character-creator/src/*"],
      // Type-only resolution for cross-repo amg-engine source files.
      // These don't go through Metro (Metro uses node resolution from
      // nodeModulesPaths in metro.config.js); they exist purely so that
      // tsc can find type declarations when compiling amg-engine sources
      // pulled in via the include glob. Without these, npx tsc --noEmit
      // emits TS2307 "Cannot find module 'react-native'" for every
      // amg-engine file that imports a peer dep.
      "react-native": ["./node_modules/react-native"],
      "react-native/*": ["./node_modules/react-native/*"],
      "@react-three/fiber": ["./node_modules/@react-three/fiber"],
      "@react-three/fiber/*": ["./node_modules/@react-three/fiber/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../amg-engine/packages/*/src/**/*.ts",
    "../amg-engine/packages/*/src/**/*.tsx"
  ]
}
