{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@amg/character-runtime": ["../amg-engine/packages/character-runtime/src/index"],
      "@amg/character-runtime/*": ["../amg-engine/packages/character-runtime/src/*"],
      "@amg/character-creator": ["../amg-engine/packages/character-creator/src/index"],
      "@amg/character-creator/*": ["../amg-engine/packages/character-creator/src/*"],
      "@amg/cosmetic-ui": ["../amg-engine/packages/cosmetic-ui/src/index"],
      "@amg/cosmetic-ui/*": ["../amg-engine/packages/cosmetic-ui/src/*"],
      "@amg/cosmetic-runtime": ["../amg-engine/packages/cosmetic-runtime/src/index"],
      "@amg/cosmetic-runtime/*": ["../amg-engine/packages/cosmetic-runtime/src/*"],
      // Type-only resolution for cross-repo amg-engine source files.
      // These don't go through Metro (Metro uses node resolution from
      // nodeModulesPaths in metro.config.js); they exist purely so that
      // tsc can find type declarations when compiling amg-engine sources
      // pulled in via the include glob. Without these, npx tsc --noEmit
      // emits TS2307 "Cannot find module 'react'" for every amg-engine
      // file that imports a peer dep.
      "react": ["./node_modules/@types/react"],
      "three": ["./node_modules/@types/three"],
      "three/*": ["./node_modules/@types/three/*"],
      "react-native": ["./node_modules/react-native"],
      "react-native/*": ["./node_modules/react-native/*"],
      "@react-three/fiber": ["./node_modules/@react-three/fiber"],
      "@react-three/fiber/*": ["./node_modules/@react-three/fiber/*"],
      // The new @amg/cosmetic-* packages were scaffolded 2026-05-04 with
      // peerDeps on Drop4's installed RN ecosystem. tsc resolves them
      // through Drop4's node_modules — same trick the existing engine
      // packages above use.
      "react-native-reanimated": ["./node_modules/react-native-reanimated"],
      "react-native-reanimated/*": ["./node_modules/react-native-reanimated/*"],
      "expo-linear-gradient": ["./node_modules/expo-linear-gradient"],
      "expo-linear-gradient/*": ["./node_modules/expo-linear-gradient/*"],
      // AMG identity layer packages (scaffolded 2026-05-13)
      "@amg/types": ["../amg-engine/packages/types/src/index"],
      "@amg/types/*": ["../amg-engine/packages/types/src/*"],
      "@amg/account": ["../amg-engine/packages/account/src/index"],
      "@amg/account/*": ["../amg-engine/packages/account/src/*"],
      "@amg/wallet": ["../amg-engine/packages/wallet/src/index"],
      "@amg/wallet/*": ["../amg-engine/packages/wallet/src/*"],
      "@amg/inventory": ["../amg-engine/packages/inventory/src/index"],
      "@amg/inventory/*": ["../amg-engine/packages/inventory/src/*"],
      "@amg/game-state": ["../amg-engine/packages/game-state/src/index"],
      "@amg/game-state/*": ["../amg-engine/packages/game-state/src/*"],
      "@amg/iap": ["../amg-engine/packages/iap/src/index"],
      "@amg/iap/*": ["../amg-engine/packages/iap/src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../amg-engine/packages/*/src/**/*.ts",
    "../amg-engine/packages/*/src/**/*.tsx"
  ]
}
