{
  "name": "drop4",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "convert-fbx": "node tools/fbx_to_glb_batch.js",
    "stage-anims": "node tools/copy_animations.js",
    "gen-outfits": "node tools/generate_outfit_registry.js",
    "test": "jest"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "./jest.setup.js"
    ],
    "moduleNameMapper": {
      "^react-native$": "<rootDir>/jest.rn-mock.js",
      "^@react-three/fiber/native$": "<rootDir>/jest.r3f-mock.js",
      "^three$": "<rootDir>/jest.three-mock.js",
      "^three/examples/jsm/loaders/GLTFLoader.js$": "<rootDir>/jest.three-mock.js",
      "\\.(glb|gltf|png|jpg|jpeg|gif|webp|svg|mp3|wav|ttf|otf)$": "<rootDir>/jest.asset-mock.js"
    },
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": ["babel-jest", { "presets": ["babel-preset-expo"] }]
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/fbx_export/",
      "/tools/"
    ]
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@react-three/fiber": "^9.6.0",
    "@shopify/react-native-skia": "2.2.12",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.12",
    "expo-av": "~16.0.8",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-gl": "~16.0.10",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-notifications": "~0.32.16",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-three": "^8.0.0",
    "firebase": "^12.11.0",
    "lottie-react-native": "^7.3.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-view-shot": "^4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.8.1",
    "three": "^0.183.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "@types/three": "^0.183.1",
    "fbx2gltf": "^0.9.7-p1",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.16",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
